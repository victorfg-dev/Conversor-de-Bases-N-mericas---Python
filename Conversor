# Conversor de bases (2 ao 16)
# Código de entrada de bases (basei = base inicial; basef = basefinal)
# Logo abaixo dos inputs, o teste para saber se a base e o número são compatíveis
validation = True
while validation == True:
    n = str(input('Digite um número em qualquer base: ')).strip().upper()
    basei = int(input('Digite a base do número digitado: '))
    carac = len(n.strip())
    
    if basei>16 or basei<2:
        print('Erro. Base inválida.')
        continue
    
    erro = False
    for d in range(0, carac):
        if n[d] not in '0123456789ABCDEF'[:basei]:
            print('Base incompatível com o número.')
            erro = True
            break
    if erro == True:
        continue

    validation = False  

# Cálculo para ler caracteres, atribuir valores numéricos e conversão para base 10
    
vlr = 0 # valor das letras
vlrnum = 0 # valor dos números
expo = 0 # expoente
soma = 0 # resultado da conversão a base 10
for c in range(carac - 1, -1, -1):
    if n[c] in 'ABCDEF':
        vlr = ord(n[c]) - 55
        soma += (vlr * (basei ** expo))
    elif n[c] in '0123456789':
        vlrnum = int(n[c])
        soma += (vlrnum * (basei ** expo))
    expo += 1
        
print(soma)

# Passando da base 10 para a basef (base final)
# teste dr conversão da base 10 a basef (base final)
basef = int(input('Qual a base para conversão (entre 2 e 16): ')) # base final
resto = 0 # resto
result = '' # resultado final

while soma > 0:
    resto = (soma % basef)
    if resto >= 10:
        result = chr(resto + 55) + result
    else:
        result = str(resto) + result
    soma = soma // basef

print('O número ', n, ' na base ', basei, ' convertido para a base ', basef, ' é: ', result)
